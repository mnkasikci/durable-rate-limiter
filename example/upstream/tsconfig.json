{
  // Extends the root config verify-style; imports from `dist/`, typecheck only.
  // Run with: npm run example:typecheck  (after npm run build)
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    "noEmit": true,
    "declaration": false,
    "emitDeclarationOnly": false
  },
  "include": ["src", "../shared"]
}
